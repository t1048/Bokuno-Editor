{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:window:allow-close",
    "dialog:default",
    "dialog:allow-ask",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "http://**" }, { "url": "https://**" }]
    }
  ]
}
